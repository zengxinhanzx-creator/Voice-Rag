# Copy to .env — full table in SPEC.md §8.

# LLM (LiteLLM model id)
VOICERAG_LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Embeddings: local (sentence-transformers) or litellm API
VOICERAG_EMBED_MODE=local
VOICERAG_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

VOICERAG_DATA_DIR=./data
VOICERAG_TOP_K=5
VOICERAG_CHUNK_SIZE=800
VOICERAG_CHUNK_OVERLAP=100
VOICERAG_RRF_K=60
VOICERAG_STRICT_TENANT=0
VOICERAG_LOG_LEVEL=INFO

# Optional: protect /api/v1/admin/* when set (P1.2)
# VOICERAG_ADMIN_TOKEN=
